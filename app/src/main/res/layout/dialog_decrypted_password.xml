<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/decrypted_password_dialog_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/nav_popup_background"
        android:orientation="vertical"
        android:padding="16dp">
    
        <TextView
            android:id="@+id/decrypted_password_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:text="Decrypted Password"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    
        <TextView
            android:id="@+id/decrypted_password_hidden_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="Password hidden"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    
        <ScrollView
            android:id="@+id/decrypted_password_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="360dp"
            android:visibility="gone">
    
            <TextView
                android:id="@+id/decrypted_password_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:textColor="#FFFFFF"
                android:textIsSelectable="true"
                android:textSize="18sp" />
    
        </ScrollView>
    
        <Button
            android:id="@+id/decrypted_password_copy_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Copy to Clipboard" />
    
        <Button
            android:id="@+id/decrypted_password_show_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Plaintext" />
    
        <Button
            android:id="@+id/decrypted_password_close_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Close" />
    
    </LinearLayout>
</FrameLayout>
