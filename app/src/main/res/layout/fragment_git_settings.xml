<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="16dp"
    android:paddingEnd="24dp"
    android:paddingBottom="12dp">

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/git_settings_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Configure your Git repository."
                android:textSize="16sp" />

            <ProgressBar
                android:id="@+id/git_settings_loading_bar"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:indeterminate="true"
                android:visibility="gone" />

        </LinearLayout>
    
    </ScrollView>

    <EditText
        android:id="@+id/repository_url_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Repository URL"
        android:inputType="textUri" />

    <EditText
        android:id="@+id/git_username_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Git username"
        android:inputType="text" />

    <EditText
        android:id="@+id/git_password_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Git password"
        android:inputType="textPassword" />

    <Button
        android:id="@+id/save_git_settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Settings" />

    <Button
        android:id="@+id/test_git_credentials_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test Credentials" />

    <Button
        android:id="@+id/clear_git_settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear Settings" />

</LinearLayout>
